# LLM provider (OpenAI used by default in lib/agent/llm.js)
OPENAI_API_KEY=sk-...

# Optional: change the model (defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Web search provider for the research nodes.
# Get a free key at https://tavily.com
TAVILY_API_KEY=tvly-...

# Optional: structured financial data (market cap, P/E, price, etc.) for
# public companies. Without this, the agent falls back to search-only
# financial signal, which still works but is less precise on hard numbers.
# Get a free key at https://financialmodelingprep.com
FMP_API_KEY=...
