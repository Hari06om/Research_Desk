# LLM provider.
# The agent uses Groq through the OpenAI-compatible LangChain client.
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Web search provider for research nodes.
# Get a key at https://tavily.com
TAVILY_API_KEY=tvly-...

# Optional structured financial data provider.
# Get a key at https://financialmodelingprep.com
FMP_API_KEY=...

# MongoDB Atlas connection string for authentication.
MONGO_URI=mongodb+srv://username:password@cluster.xxx.mongodb.net/researchdesk?retryWrites=true&w=majority

# Optional backend port.
PORT=3001
